# =====================================================
# PostgreSQL (db サービス / PostGIS)
# =====================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=location_explorer
POSTGRES_PORT=5432
# バックエンド(TypeORM)がDBコンテナに接続する際のホスト名。
# docker-compose内部ではサービス名 "db" がそのままホスト名として解決される。
DB_HOST=db

# =====================================================
# バックエンド (NestJS)
# =====================================================
# ホストからAPIに直接アクセスするためのポート（コンテナ内部は常に3001固定）。
BACKEND_PORT=3001

# =====================================================
# フロントエンド (Next.js)
# =====================================================
# ホストからFEに直接アクセスするためのポート（コンテナ内部は常に3000固定）。
FRONTEND_PORT=3000

# =====================================================
# Google Maps API
# =====================================================
# 逆ジオコーディング用（バックエンドのみで使用。フロントには絶対に露出させない）
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# 地図表示用（フロントエンドで使用。NEXT_PUBLIC_ を付けるとブラウザに露出するため、
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
